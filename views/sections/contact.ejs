<section id="contacto" class="py-16 bg-gray-100">
    <div class="container mx-auto px-4">
        <h2 class="text-4xl font-bold text-center text-gray-800 mb-10">Contáctame</h2>
        
        <!-- Contenedor de Mensajes de Estado (Éxito/Error) -->
        <div id="statusMessage" class="mb-4 text-center hidden"></div>

        <!-- El FORMULARIO - Nota: El action y method se eliminan, el envío es por JS -->
        <form id="contactForm" class="max-w-xl mx-auto p-8 bg-white shadow-xl rounded-lg">
            <div class="mb-6">
                <label for="from_name" class="block text-gray-700 font-semibold mb-2">Tu Nombre</label>
                <input type="text" id="from_name" name="from_name" required
                       class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-indigo-500">
            </div>

            <div class="mb-6">
                <label for="from_email" class="block text-gray-700 font-semibold mb-2">Tu Correo Electrónico</label>
                <input type="email" id="from_email" name="from_email" required
                       class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-indigo-500">
            </div>

            <div class="mb-6">
                <label for="message" class="block text-gray-700 font-semibold mb-2">Mensaje</label>
                <textarea id="message" name="message" rows="6" required
                          class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-indigo-500"></textarea>
            </div>

            <button type="submit" id="submitButton"
                    class="w-full bg-indigo-600 text-white font-bold py-3 px-4 rounded-lg hover:bg-indigo-700 transition duration-300 disabled:opacity-50"
                    aria-label="Enviar Mensaje">
                Enviar Mensaje
            </button>
        </form>
    </div>
</section>

<!-- 3. JAVASCRIPT DE ENVÍO DE EMAILJS -->
<script>
    document.addEventListener('DOMContentLoaded', function () {
        const form = document.getElementById('contactForm');
        const statusMessage = document.getElementById('statusMessage');
        const submitButton = document.getElementById('submitButton');

        form.addEventListener('submit', function (event) {
            event.preventDefault();

            // Deshabilitar botón y mostrar cargando
            submitButton.disabled = true;
            submitButton.textContent = 'Enviando...';
            statusMessage.textContent = '';
            statusMessage.classList.add('hidden');

            // Parámetros del servicio EmailJS
            const serviceID = "MNseVKSK3D6tYwfwV";
            const templateID = "template_6cq3ak2";
            
            // Los parámetros del correo se obtienen automáticamente del formulario
            // ya que los campos (from_name, from_email, message) coinciden con la plantilla.

            emailjs.sendForm(serviceID, templateID, form)
                .then(function() {
                    // Éxito:
                    statusMessage.textContent = '¡Mensaje enviado con éxito! Te contactaré pronto.';
                    statusMessage.className = 'mb-4 p-3 bg-green-100 text-green-700 border border-green-400 rounded-lg text-center';
                    form.reset(); // Limpiar el formulario
                }, function(error) {
                    // Error:
                    console.error('EmailJS Error:', error);
                    statusMessage.textContent = 'Error al enviar el mensaje. Intenta más tarde.';
                    statusMessage.className = 'mb-4 p-3 bg-red-100 text-red-700 border border-red-400 rounded-lg text-center';
                })
                .finally(function() {
                    // Habilitar botón de nuevo
                    submitButton.disabled = false;
                    submitButton.textContent = 'Enviar Mensaje';
                    statusMessage.classList.remove('hidden');
                });
        });
    });
</script>
