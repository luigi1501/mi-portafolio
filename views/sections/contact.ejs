<section class="contact-section" id="contacto">
  <h2 class="page-title">Contactar Ahora</h2>
  <p class="subtitle">
    Estoy disponible para nuevos proyectos o consultas. Te responderé en menos
    de 24 horas.
  </p>

  <% if (success) { %>
  <div class="alert alert-success">
    <strong>¡Mensaje Enviado!</strong> <%= success %>
  </div>
  <% } %><% if (error) { %>
  <div class="alert alert-error">
    <strong>Error al Enviar:</strong> <%= error %>
  </div>
  <% } %>

  <form action="/contacto" method="POST" class="contact-form">
    <div class="form-group">
      <label for="nombre">Nombre Completo</label>
      <input
        type="text"
        id="nombre"
        name="nombre"
        required
        placeholder="Tu Nombre"
        class="form-input"
      />
    </div>
    <div class="form-group">
      <label for="email">Correo Electrónico</label>
      <input
        type="email"
        id="email"
        name="email"
        required
        placeholder="tu.correo@ejemplo.com"
        class="form-input"
      />
    </div>
    <div class="form-group">
      <label for="mensaje">Mensaje</label>
      <textarea
        id="mensaje"
        name="mensaje"
        rows="6"
        required
        placeholder="Cuéntame sobre tu proyecto o consulta..."
        class="form-textarea"
      ></textarea>
    </div>
    <button type="submit" class="btn btn-primary">Enviar Mensaje</button>
  </form>
</section>
