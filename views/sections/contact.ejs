<!-- LA SECCIÓN DE CONTACTO CON TUS CLASES CSS PERSONALIZADAS -->
<section class="contact-section" id="contacto">
    <h2 class="page-title">Contactar Ahora</h2>
    <p class="subtitle">
        Estoy disponible para nuevos proyectos o consultas. Te responderé en menos
        de 24 horas.
    </p>

    <!-- Contenedor de Mensajes de Estado (Éxito/Error) - Usará las clases alert-success/alert-error -->
    <!-- Inicialmente oculto por JS, se muestra después del intento de envío. -->
    <div id="statusMessage" class="alert hidden"></div>

    <!-- El FORMULARIO - Nota: El action y method se eliminan, el envío es por JS de EmailJS -->
    <form id="contactForm" class="contact-form">
        <div class="form-group">
            <label for="from_name">Nombre Completo</label>
            <!-- Importante: Los nombres de los campos deben coincidir con tu plantilla de EmailJS -->
            <input
                type="text"
                id="from_name"
                name="from_name"
                required
                placeholder="Tu Nombre"
                class="form-input"
            />
        </div>
        <div class="form-group">
            <label for="from_email">Correo Electrónico</label>
            <input
                type="email"
                id="from_email"
                name="from_email"
                required
                placeholder="tu.correo@ejemplo.com"
                class="form-input"
            />
        </div>
        <div class="form-group">
            <label for="message">Mensaje</label>
            <textarea
                id="message"
                name="message"
                rows="6"
                required
                placeholder="Cuéntame sobre tu proyecto o consulta..."
                class="form-textarea"
            ></textarea>
        </div>
        <button type="submit" id="submitButton" class="btn btn-primary">Enviar Mensaje</button>
    </form>
</section>

<!-- 3. JAVASCRIPT DE ENVÍO DE EMAILJS -->
<script>
    document.addEventListener('DOMContentLoaded', function () {
        const form = document.getElementById('contactForm');
        const statusMessage = document.getElementById('statusMessage');
        const submitButton = document.getElementById('submitButton');

        form.addEventListener('submit', function (event) {
            event.preventDefault();

            // Deshabilitar botón y mostrar cargando
            submitButton.disabled = true;
            submitButton.textContent = 'Enviando...';
            statusMessage.textContent = '';
            statusMessage.classList.add('hidden');
            statusMessage.className = 'alert hidden'; // Limpiar clases de éxito/error anteriores

            // Parámetros del servicio EmailJS
            // 🚨 ¡Paso Final! Reemplaza esta cadena con el Service ID REAL (que comienza con 'service_').
            const serviceID = "service_aqui_va_el_id_real"; 
            
            // 🟢 CORREGIDO: Usando el Template ID encontrado en el historial de EmailJS.
            const templateID = "egs-test-mail-service";
            
            // Los parámetros del correo se obtienen automáticamente del formulario
            // ya que los campos (from_name, from_email, message) coinciden con la plantilla.

            emailjs.sendForm(serviceID, templateID, form)
                .then(function() {
                    // Éxito:
                    statusMessage.innerHTML = '<strong>¡Mensaje Enviado!</strong> Te contactaré pronto.';
                    statusMessage.classList.add('alert-success');
                    form.reset(); // Limpiar el formulario
                }, function(error) {
                    // Error:
                    console.error('EmailJS Error:', error);
                    statusMessage.innerHTML = '<strong>Error al Enviar:</strong> Intenta más tarde. Código de error: ' + error.status;
                    statusMessage.classList.add('alert-error');
                })
                .finally(function() {
                    // Habilitar botón de nuevo
                    submitButton.disabled = false;
                    submitButton.textContent = 'Enviar Mensaje';
                    statusMessage.classList.remove('hidden');
                });
        });
    });
</script>
