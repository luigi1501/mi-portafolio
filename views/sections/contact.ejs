<section class="contact-section" id="contacto">
    <h2 class="page-title">Contactar Ahora</h2>
    <p class="subtitle">
        Estoy disponible para nuevos proyectos o consultas. Te responderé en menos
        de 24 horas.
    </p>

    <!-- Contenedor de Mensajes de Estado (Éxito/Error) -->
    <div id="statusMessage" class="alert hidden"></div>

    <!-- El FORMULARIO - Envío manejado por JavaScript -->
    <form id="contactForm" class="contact-form">
        <div class="form-group">
            <label for="from_name">Nombre Completo</label>
            <input
                type="text"
                id="from_name"
                name="from_name"
                required
                placeholder="Tu Nombre"
                class="form-input"
            />
        </div>
        <div class="form-group">
            <label for="from_email">Correo Electrónico</label>
            <input
                type="email"
                id="from_email"
                name="from_email"
                required
                placeholder="tu.correo@ejemplo.com"
                class="form-input"
            />
        </div>
        <div class="form-group">
            <label for="message">Mensaje</label>
            <textarea
                id="message"
                name="message"
                rows="6"
                required
                placeholder="Cuéntame sobre tu proyecto o consulta..."
                class="form-textarea"
            ></textarea>
        </div>
        <button type="submit" id="submitButton" class="btn btn-primary">Enviar Mensaje</button>
    </form>
</section>

<!-- 2. JAVASCRIPT DE ENVÍO DE EMAILJS -->
<script>
    document.addEventListener('DOMContentLoaded', function () {
        const form = document.getElementById('contactForm');
        const statusMessage = document.getElementById('statusMessage');
        const submitButton = document.getElementById('submitButton');

        form.addEventListener('submit', function (event) {
            event.preventDefault();

            // Deshabilitar botón y limpiar mensajes
            submitButton.disabled = true;
            submitButton.textContent = 'Enviando...';
            statusMessage.textContent = '';
            statusMessage.className = 'alert hidden'; 

            // Parámetros del servicio EmailJS
            // 🟢 Service ID: ¡CORREGIDO! Usando el Service ID que generaste con el formato correcto.
            const serviceID = "service_akz9jkw"; 
            
            // 🟢 Template ID: Confirmado
            const templateID = "template_6cq3ak2";
            
            emailjs.sendForm(serviceID, templateID, form)
                .then(function() {
                    // Éxito:
                    statusMessage.innerHTML = '<strong>¡Mensaje Enviado!</strong> Te contactaré pronto.';
                    statusMessage.classList.add('alert-success');
                    form.reset(); // Limpiar el formulario
                }, function(error) {
                    // Error:
                    console.error('EmailJS Error:', error);
                    // Muestra un mensaje detallado en caso de fallo
                    statusMessage.innerHTML = `<strong>Error al Enviar:</strong> Intenta más tarde. Verifica las claves y permisos. Código de error: ${error.status || 'Desconocido'}.`;
                    statusMessage.classList.add('alert-error');
                })
                .finally(function() {
                    // Habilitar botón de nuevo
                    submitButton.disabled = false;
                    submitButton.textContent = 'Enviar Mensaje';
                    statusMessage.classList.remove('hidden');
                });
        });
    });
</script>
